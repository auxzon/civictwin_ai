# =============================================================
# CivicTwin AI — Backend Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# =============================================================

# --- Application ---
ENVIRONMENT=development          # development | staging | production
APP_NAME=CivicTwin AI Backend
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:8080

# --- Gemini Developer API (Decision 1: google-genai, NOT Vertex AI) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.15
GEMINI_TOP_P=0.95

# --- Firebase Admin SDK (Decision 2) ---
# Path to the downloaded Firebase service account JSON key.
GOOGLE_APPLICATION_CREDENTIALS=./firebase/service-account.json
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# --- Cache Configuration (ai_cache collection) ---
AI_CACHE_TTL_HOURS=2

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=15

# --- Request Timeout ---
REQUEST_TIMEOUT_SECONDS=45
